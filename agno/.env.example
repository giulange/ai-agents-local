# =============================================================================
# Engineering Copilot — variabili d'ambiente
# Copiare in .env e compilare i valori richiesti.
# =============================================================================

# --- Telegram (obbligatorio) -------------------------------------------------
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_ALLOWED_CHAT_IDS=123456789,987654321   # opzionale: lasciare vuoto per nessun filtro

# --- Ollama (LLM locale, primario) ------------------------------------------
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_EMBED_MODEL=nomic-embed-text

# --- Anthropic (cloud, opzionale — fallback o agenti specializzati) ----------
ANTHROPIC_API_KEY=

# --- OpenAI (opzionale — solo trascrizione audio via Whisper) ---------------
OPENAI_API_KEY=
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe

# --- Persistenza ------------------------------------------------------------
AGNO_DB_FILE=state/agents.db

# --- Paths ------------------------------------------------------------------
REPOS_BASE_DIR=~/git          # radice di tutti i repo clonati
TOOLS_BASE_DIR=.
TOOLS_OUTPUT_DIR=logs/generated

# --- Logging e debug --------------------------------------------------------
LOG_LEVEL=INFO
AGNO_DEBUG_MODE=false
AGNO_DEBUG_LEVEL=1
HTTPX_LOG_LEVEL=WARNING

# --- Limiti -----------------------------------------------------------------
ATTACHMENT_TEXT_CHAR_LIMIT=24000

# --- PostgreSQL (opzionale) -------------------------------------------------
# POSTGRES_DB_NAME=
# POSTGRES_USER=
# POSTGRES_PASSWORD=
# POSTGRES_HOST=
# POSTGRES_PORT=5432
# POSTGRES_SCHEMA=public
