# =============================================================================
# Engineering Copilot — variabili d'ambiente
# Copiare in .env e compilare i valori richiesti.
# =============================================================================

# --- Telegram (obbligatorio) -------------------------------------------------
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_ALLOWED_CHAT_IDS=          # opzionale: chat IDs separati da virgola

# --- OpenAI (opzionale — solo trascrizione audio via Whisper) ---------------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe

# --- Anthropic (opzionale — agenti cloud) -----------------------------------
ANTHROPIC_API_KEY=

# --- Ollama (LLM locale, primario) ------------------------------------------
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# --- Persistenza e paths -----------------------------------------------------
AGNO_DB_FILE=data/agents.db
GIT_REPOS_BASE_DIR=~/git
KNOWLEDGE_STORE_PATH=knowledge/lancedb

# --- Tools -------------------------------------------------------------------
TOOLS_BASE_DIR=.
TOOLS_OUTPUT_DIR=data/generated
CSV_TOOL_GLOB=**/*.csv

# --- Runtime skills ----------------------------------------------------------
RUNTIME_SKILLS_DIR=skills/runtime
ENABLED_RUNTIME_SKILLS=pdf,pptx,brainstorming

# --- Logging e debug ---------------------------------------------------------
LOG_LEVEL=INFO
AGNO_DEBUG_MODE=false
AGNO_DEBUG_LEVEL=1
HTTPX_LOG_LEVEL=WARNING

# --- Limiti ------------------------------------------------------------------
ATTACHMENT_TEXT_CHAR_LIMIT=24000

# --- PostgreSQL (opzionale) --------------------------------------------------
# POSTGRES_DB_NAME=
# POSTGRES_USER=
# POSTGRES_PASSWORD=
# POSTGRES_HOST=
# POSTGRES_PORT=5432
# POSTGRES_SCHEMA=public
